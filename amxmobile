<!-- ─── MAIN CONTENT ─── -->
<div class="main">

  <!-- TOP BAR -->
  <div class="topbar">
    <div class="topbar-breadcrumb">
      Shiloh &rsaquo; <span id="breadcrumb-current">Dashboard</span>
    </div>
    <div class="topbar-actions">
      <button class="btn-sm">&#9881; Settings</button>
      <button class="btn-sm btn-primary" onclick="openBuilder()">+ New Report</button>
