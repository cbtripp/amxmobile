    </a>
    <a class="sidebar-item">
      <span style="font-size:14px;">&#9881;</span> Templates
    </a>
    <a class="sidebar-item">
      <span style="font-size:14px;">&#128202;</span> History
    </a>
  </div>

  <div class="sidebar-divider"></div>

  <div class="sidebar-section">
    <div class="sidebar-section-label">Portfolio Companies</div>
    <a class="sidebar-item co-amx" onclick="selectCompany('amx')">
