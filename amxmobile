          <span><span class="status-dot status-live"></span> Live</span>
          <span>16,042 loads</span>
        </div>
      </div>
      <!-- AMXL -->
      <div class="suite-card" onclick="selectCompany('amxl')">
        <div class="suite-card-accent" style="background:linear-gradient(90deg,#9c0e27,#C41230);"></div>
        <div class="suite-card-icon" style="background:rgba(196,18,48,0.1);color:#ff8fa0;">AXL</div>
        <div class="suite-card-name">AMXL</div>
        <div class="suite-card-desc">Logistics arm. Brokerage operations and managed freight.</div>
        <div class="suite-card-meta">
          <span><span class="status-dot status-live"></span> Live</span>
          <span>8,214 loads</span>
        </div>
      </div>
      <!-- JIT-EX -->
      <div class="suite-card" onclick="selectCompany('jitex')">
        <div class="suite-card-accent" style="background:linear-gradient(90deg,#2563eb,#60a5fa);"></div>
        <div class="suite-card-icon" style="background:rgba(59,130,246,0.15);color:#93bbfd;">JIT</div>
        <div class="suite-card-name">JIT-EX</div>
        <div class="suite-card-desc">Just In Time Express. Regional carrier — Memphis &amp; Nashville.</div>
        <div class="suite-card-meta">
          <span><span class="status-dot status-pending"></span> Onboarding</span>
          <span>265 tractors</span>
        </div>
      </div>
      <!-- BOOST -->
      <div class="suite-card" onclick="selectCompany('boost')">
        <div class="suite-card-accent" style="background:linear-gradient(90deg,#059669,#34d399);"></div>
        <div class="suite-card-icon" style="background:rgba(52,211,153,0.15);color:#6ee7b7;">BST</div>
        <div class="suite-card-name">Boost Transport</div>
        <div class="suite-card-desc">Managed logistics &amp; warehousing. 90,000+ sq ft warehouse network.</div>
        <div class="suite-card-meta">
          <span><span class="status-dot status-pending"></span> Onboarding</span>
          <span>90+ sites</span>
        </div>
      </div>
      <!-- BLUE PENGUIN -->
      <div class="suite-card" onclick="selectCompany('bp')">
        <div class="suite-card-accent" style="background:linear-gradient(90deg,#4f46e5,#818cf8);"></div>
        <div class="suite-card-icon" style="background:rgba(99,102,241,0.15);color:#a5b4fc;">BP</div>
        <div class="suite-card-name">Blue Penguin</div>
        <div class="suite-card-desc">Payment processing platform. Merchants, transactions, residuals.</div>
        <div class="suite-card-meta">
          <span><span class="status-dot status-live"></span> Live</span>
          <span>$40M+ rev</span>
        </div>
      </div>
      <!-- TRS -->
      <div class="suite-card" onclick="selectCompany('trs')">
        <div class="suite-card-accent" style="background:linear-gradient(90deg,#b8973f,#c9a84c);"></div>
        <div class="suite-card-icon" style="background:rgba(201,168,76,0.15);color:#c9a84c;">TRS</div>
        <div class="suite-card-name">TAG Reserve Spirits</div>
        <div class="suite-card-desc">Bradshaw Bourbon, Campesino Rum, BlueStar Tequila, Gameday Vodka, Tribini.</div>
        <div class="suite-card-meta">
          <span><span class="status-dot status-live"></span> Live</span>
          <span>5 brands</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ COMPANY VIEW ═══ -->
  <div class="content" id="view-company" style="display:none;">
    <div class="page-header">
      <div class="page-title" id="company-title">AMX Logistics</div>
      <div class="page-subtitle" id="company-subtitle">Data modules &amp; export tools for AMX Logistics.</div>
    </div>

    <!-- Tabs -->
    <div class="tabs">
      <div class="tab active" onclick="switchTab(this,'modules')">Import &amp; Export</div>
      <div class="tab" onclick="switchTab(this,'history')">History</div>
      <div class="tab" onclick="switchTab(this,'templates')">Templates</div>
      <div class="tab" onclick="switchTab(this,'schedules')">Schedules</div>
      <div class="tab" onclick="switchTab(this,'preferences')">Preferences</div>
    </div>

    <!-- Search + modules -->
    <div class="modules-section" id="tab-modules">
      <div class="modules-header">
        <div class="modules-title">Data Modules <span class="count" id="module-count">8</span></div>
        <input class="module-search" placeholder="Search modules..." oninput="filterModules(this.value)">
      </div>
      <div class="module-list" id="module-list">
        <!-- Populated by JS -->
      </div>
    </div>

    <!-- Builder Panel -->
    <div class="builder-panel" id="builder-panel">
      <div class="builder-header">
        <div class="builder-title" id="builder-title">Export Orders</div>
        <button class="builder-close" onclick="closeBuilder()">&times;</button>
      </div>
      <div class="builder-body">
        <div class="builder-section">
          <div class="builder-label">Template</div>
          <select class="builder-select" id="builder-template">
            <option>Default Export</option>
            <option>Factor View Reconciliation (CBT)</option>
            <option>Carrier Settlement Report</option>
            <option>Monthly P&L Summary</option>
            <option>Custom...</option>
          </select>
        </div>
        <div class="builder-section">
          <div class="builder-label">Date Range</div>
          <select class="builder-select">
            <option>Last 7 days</option>
            <option>Last 30 days</option>
            <option>This month</option>
            <option>Last quarter</option>
            <option>Year to date</option>
            <option>All time</option>
            <option>Custom range...</option>
          </select>
        </div>
        <div class="builder-section">
          <div class="builder-label">File Type</div>
          <div class="builder-toggle-group">
            <button class="builder-toggle active">CSV</button>
            <button class="builder-toggle">Excel</button>
            <button class="builder-toggle">JSON</button>
            <button class="builder-toggle">PDF</button>
          </div>
        </div>
        <div class="builder-section">
          <div class="builder-label">Delivery Method</div>
          <div class="builder-toggle-group">
            <button class="builder-toggle active">Download</button>
            <button class="builder-toggle">Email</button>
            <button class="builder-toggle">SFTP</button>
            <button class="builder-toggle">Zapier</button>
          </div>
        </div>
        <div class="builder-fields">
          <div class="builder-label">Included Fields <span style="color:var(--text-3);font-weight:400;text-transform:none;letter-spacing:0;">(click to toggle)</span></div>
          <div class="field-chips" id="field-chips">
            <!-- Populated by JS -->
          </div>
        </div>
      </div>
      <div class="builder-footer">
        <button class="btn-sm">Cancel</button>
        <button class="btn-sm" onclick="alert('Schedule saved.')">&#128339; Schedule Export</button>
        <button class="btn-sm btn-primary" onclick="runExport()">Export Now &rarr;</button>
      </div>
    </div>
  </div>

</div>

<!-- ═══ TOAST ═══ -->
<div id="toast" style="position:fixed;bottom:24px;right:24px;background:var(--bg-3);border:1px solid var(--green);color:var(--green);padding:12px 20px;border-radius:8px;font-size:13px;font-weight:600;opacity:0;transform:translateY(10px);transition:all 0.3s;pointer-events:none;z-index:100;">
  &#10003; Export queued successfully.
</div>

<script>
// ─── DATA ───
const companies = {
  amx: {
    name: "AMX Logistics",
    desc: "Data modules & export tools for AMX Logistics.",
    modules: [
      { name: "Orders", fields: ["Load #","Customer","Origin City","Origin State","Dest City","Dest State","Pickup Date","Delivery Date","Carrier","Rate","Status","Equipment Type","Miles","Weight","Commodity"], template: "BILL", lastExport: "Mar 25, 2026", hasImport: true },
      { name: "Carriers", fields: ["Carrier ID","Carrier Name","MC #","DOT #","Contact","Phone","Email","Insurance Exp","Status","Rating","Pay Terms"], template: "BILL", lastExport: "Mar 22, 2026", hasImport: true },
      { name: "Settlements", fields: ["Settlement ID","Carrier","Load #","Amount","Deductions","Net Pay","Payment Date","Method","Status"], template: "BILL", hasImport: false },
      { name: "Invoices", fields: ["Invoice #","Customer Name","Amount","Payment Status","Line Item Amount","Line Item Location","Due Date","Issued Date"], template: "BILL", lastExport: "Mar 25, 2026", hasImport: true },
      { name: "Payments", fields: ["Payment ID","Vendor","Amount","Date","Method","Reference","Status","Account"], template: "BILL", hasImport: false },
      { name: "Customers", fields: ["Customer ID","Company Name","Contact","Phone","Email","Address","City","State","Zip","Credit Limit","Terms","Status"], template: "BILL", hasImport: true },
      { name: "Fuel & Expenses", fields: ["Transaction Date","Driver","Truck #","Location","Gallons","Price/Gal","Total","Category","Vendor"], template: "BILL", hasImport: true },
      { name: "Lane Analytics", fields: ["Origin","Destination","Avg Rate","Load Count","Avg Miles","Top Carrier","Margin %","Trend"], template: "BILL", hasImport: false },
    ]
  },
  amxl: {
    name: "AMXL",
    desc: "Data modules & export tools for AMXL brokerage operations.",
    modules: [
      { name: "Brokered Loads", fields: ["Load #","Shipper","Carrier","Origin","Destination","Rate","Margin","Status","Booked Date"], template: "BILL", hasImport: true },
      { name: "Carrier Payments", fields: ["Payment ID","Carrier","Amount","Date","Method","Status"], template: "BILL", hasImport: false },
      { name: "Customer Invoices", fields: ["Invoice #","Customer","Amount","Status","Due Date"], template: "BILL", lastExport: "Mar 24, 2026", hasImport: true },
      { name: "Margin Report", fields: ["Period","Revenue","Carrier Cost","Gross Margin","Margin %","Load Count"], template: "BILL", hasImport: false },
    ]
  },
  jitex: {
    name: "JIT-EX",
    desc: "Data modules for Just In Time Express — Memphis & Nashville.",
    modules: [
      { name: "Fleet", fields: ["Tractor #","Type","Year","Make","Model","Status","Assigned Driver","Mileage","Last Service"], template: "BILL", hasImport: true },
      { name: "Drivers", fields: ["Driver ID","Name","CDL #","CDL Exp","Hire Date","Status","Home Terminal","Assigned Tractor"], template: "BILL", hasImport: true },
      { name: "Loads", fields: ["Load #","Customer","Origin","Destination","Driver","Tractor","Rate","Status","Pickup Date"], template: "BILL", hasImport: true },
      { name: "Maintenance", fields: ["Work Order #","Tractor #","Date","Type","Description","Cost","Vendor","Status"], template: "BILL", hasImport: true },
    ]
  },
  boost: {
    name: "Boost Transport",
    desc: "Data modules for Boost Transport managed logistics & warehousing.",
    modules: [
      { name: "Warehouse Inventory", fields: ["SKU","Product Name","Quantity","Location","Zone","Last Updated","Client"], template: "BILL", hasImport: true },
      { name: "Shipments", fields: ["Shipment ID","Client","Origin Warehouse","Destination","Carrier","Status","Ship Date","Tracking #"], template: "BILL", hasImport: true },
      { name: "Fulfillment Orders", fields: ["Order ID","Client","Platform","Items","Status","Ship Date","Tracking"], template: "BILL", hasImport: true },
      { name: "Clients", fields: ["Client ID","Company","Contact","Phone","Email","Warehouse Location","Contract Start"], template: "BILL", hasImport: true },
    ]
  },
  bp: {
    name: "Blue Penguin",
    desc: "Data modules for Blue Penguin payment processing.",
    modules: [
      { name: "Merchants", fields: ["Merchant ID","Business Name","Contact","Status","MCC","Processing Volume","Residual %"], template: "BILL", hasImport: true },
      { name: "Transactions", fields: ["Transaction ID","Merchant","Amount","Date","Card Type","Status","Fee"], template: "BILL", hasImport: false },
      { name: "Residuals", fields: ["Period","Agent","Merchant","Volume","Revenue","Residual Amount","Status"], template: "BILL", hasImport: false },
      { name: "Chargebacks", fields: ["Case ID","Merchant","Amount","Date","Reason Code","Status","Resolution"], template: "BILL", hasImport: false },
    ]
  },
  trs: {
    name: "TAG Reserve Spirits",
    desc: "Data modules for all TRS brands: Bradshaw Bourbon, Campesino Rum, BlueStar Tequila, Gameday Vodka, Tribini.",
    modules: [
      { name: "Distributors", fields: ["Distributor ID","Company","State","Territory","Contact","Phone","Status","Brands Carried"], template: "BILL", hasImport: true },
      { name: "Sales Orders", fields: ["Order #","Distributor","Brand","SKU","Cases","Price/Case","Total","Ship Date","Status"], template: "BILL", hasImport: true },
      { name: "Inventory", fields: ["SKU","Brand","Product","Cases on Hand","Warehouse","Last Updated","Reorder Point"], template: "BILL", hasImport: true },
      { name: "Accounts Receivable", fields: ["Invoice #","Distributor","Amount","Due Date","Status","Days Outstanding"], template: "BILL", hasImport: false },
      { name: "Brand Performance", fields: ["Brand","Period","Cases Sold","Revenue","COGS","Gross Margin","Markets Active"], template: "BILL", hasImport: false },
      { name: "Compliance & Permits", fields: ["State","Permit Type","Expiration","Status","Brand","Notes"], template: "BILL", hasImport: true },
    ]
  },
};

let currentCompany = null;
let currentModule = null;

// ─── VIEW SWITCHING ───
function showView(view) {
  document.getElementById('view-home').style.display = view === 'home' ? 'block' : 'none';
  document.getElementById('view-company').style.display = view === 'company' ? 'block' : 'none';
  document.getElementById('breadcrumb-current').textContent = view === 'home' ? 'Dashboard' : companies[currentCompany]?.name || '';
  document.querySelectorAll('.sidebar-item').forEach(el => el.classList.remove('active'));
}

function selectCompany(key) {
  currentCompany = key;
  const co = companies[key];
  document.getElementById('company-title').textContent = co.name;
  document.getElementById('company-subtitle').textContent = co.desc;
  document.getElementById('module-count').textContent = co.modules.length;
  renderModules(co.modules);
  showView('company');
  closeBuilder();
  // highlight sidebar
  document.querySelectorAll('.sidebar-item').forEach(el => el.classList.remove('active'));
}

function renderModules(modules) {
  const list = document.getElementById('module-list');
  list.innerHTML = modules.map((m, i) => `
    <div class="module-card" data-name="${m.name.toLowerCase()}" style="animation-delay:${i * 0.03}s">
      <div class="module-info">
        <div class="module-name">${m.name}</div>
        <div class="module-meta">
          <span>Template: ${m.template}</span>
          ${m.lastExport ? `<span class="module-meta-dot"></span><span>Last exported ${m.lastExport}</span>` : ''}
        </div>
      </div>
      <div class="module-actions">
        ${m.hasImport ? `<button class="btn-sm" onclick="alert('Import wizard coming soon.')">Import</button>` : ''}
        <button class="btn-sm btn-primary" onclick="openModuleBuilder(${i})">Export</button>
      </div>
    </div>
  `).join('');
}

function filterModules(query) {
  const q = query.toLowerCase();
  document.querySelectorAll('.module-card').forEach(card => {
    card.style.display = card.dataset.name.includes(q) ? 'flex' : 'none';
  });
}

// ─── BUILDER ───
function openModuleBuilder(index) {
  const co = companies[currentCompany];
  const mod = co.modules[index];
  currentModule = mod;
  document.getElementById('builder-title').textContent = `Export ${mod.name}`;
  renderFieldChips(mod.fields);
  document.getElementById('builder-panel').classList.add('active');
  document.getElementById('builder-panel').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function openBuilder() {
  if (!currentCompany) {
    // default to AMX
    selectCompany('amx');
  }
  const co = companies[currentCompany];
  currentModule = co.modules[0];
  document.getElementById('builder-title').textContent = `Export ${currentModule.name}`;
  renderFieldChips(currentModule.fields);
  document.getElementById('builder-panel').classList.add('active');
}

function closeBuilder() {
  document.getElementById('builder-panel').classList.remove('active');
}

function renderFieldChips(fields) {
  const container = document.getElementById('field-chips');
  container.innerHTML = fields.map(f =>
    `<span class="field-chip selected" onclick="this.classList.toggle('selected')">${f}</span>`
  ).join('');
}

// Toggle buttons
document.addEventListener('click', e => {
  if (e.target.classList.contains('builder-toggle') && !e.target.classList.contains('active')) {
    const group = e.target.parentElement;
    group.querySelectorAll('.builder-toggle').forEach(b => b.classList.remove('active'));
    e.target.classList.add('active');
  }
});

function switchTab(el, tab) {
  el.parentElement.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  // For now just keep modules visible
}

function runExport() {
  const toast = document.getElementById('toast');
  const selected = document.querySelectorAll('.field-chip.selected').length;
  toast.textContent = `✓ Export queued — ${selected} fields from ${currentModule?.name || 'module'}. Generating file...`;
  toast.style.opacity = '1';
  toast.style.transform = 'translateY(0)';
  setTimeout(() => {
    toast.style.opacity = '0';
    toast.style.transform = 'translateY(10px)';
  }, 3500);
}
</script>
</body>
</html>
