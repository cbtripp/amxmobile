  <!-- ═══ HOME VIEW ═══ -->
  <div class="content" id="view-home">
    <div class="page-header">
      <div class="page-title">Portfolio Suite</div>
      <div class="page-subtitle">Select a company to access its data modules, reports, and export tools.</div>
